OPENAI_API_KEY=your_api_key_here

# Optional: analyst | viewer | admin (default analyst). Restricts tools + tables in dispatch.
# APP_USER_ROLE=analyst

# Optional model and cost-saving flags (1 / true / yes to disable)
# CHAT_MODEL=gpt-4o
# PEER_REVIEW_MODEL=gpt-4o-mini
# DISABLE_PLANNER=0
# DISABLE_REPORT_WRITER=0
# DISABLE_VIZ_AGENT=0
# DISABLE_CHART_NARRATIVE=0
# DISABLE_PEER_REVIEW=0
# DISABLE_FOLLOWUP_RANKING=0
# SQL_SERVER_MAX_LIMIT=10000

# Human-in-the-loop: pause before SQL with LIMIT >= threshold (Streamlit UI or terminal y/N)
# ENABLE_QUERY_APPROVAL=0
# QUERY_APPROVAL_MIN_LIMIT=1000

# Logging and tracing (stderr; optional file at outputs/logs/agent.log)
# LOG_LEVEL=INFO
# LOG_FORMAT=text
# LOG_TO_FILE=1
# LOG_FILE=outputs/logs/agent.log
